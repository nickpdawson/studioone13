---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { mediumLabel, mediumGallery, mediumGalleryLabel } from '../../lib/mediums';

export async function getStaticPaths() {
  const paintings = await getCollection('paintings');
  return paintings.map((painting) => ({
    params: { slug: painting.id },
    props: { painting },
  }));
}

const { painting } = Astro.props;
const { Content } = await render(painting);

const galleryHref = mediumGallery(painting.data.medium);
const galleryLabel = mediumGalleryLabel(painting.data.medium);
const label = mediumLabel(painting.data.medium);
---

<Base title={`${painting.data.title} · George W. Dawson`}>
  <div class="painting-detail">
    <p class="back"><a href={galleryHref}>← {galleryLabel}</a></p>

    <img src={painting.data.image} alt={painting.data.title} />

    <div>
      <h1 class="title">{painting.data.title}</h1>
      <p class="meta">
        <span>{label}</span>
        {painting.data.year && <span>{painting.data.year}</span>}
        {painting.data.dimensions && <span>{painting.data.dimensions}</span>}
        {painting.data.price && <span>{painting.data.price}</span>}
        {painting.data.sold && <span>Sold</span>}
      </p>

      <div class="note">
        <Content />
      </div>
    </div>
  </div>
</Base>
