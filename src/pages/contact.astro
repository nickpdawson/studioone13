---
import Base from '../layouts/Base.astro';
import { getEntry, render } from 'astro:content';

const page = await getEntry('pages', 'contact');
if (!page) throw new Error('Missing src/content/pages/contact.md');
const { Content } = await render(page);
---

<Base title={`${page.data.title} · George W. Dawson`}>
  <h1>{page.data.title}</h1>
  {page.data.lead && <p class="lead">{page.data.lead}</p>}
  {page.data.email && (
    <p>
      <a href={`mailto:${page.data.email}`}>{page.data.email}</a>
    </p>
  )}
  <Content />
</Base>
